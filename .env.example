# Bearer token clients must send as `Authorization: Bearer <APP_TOKEN>`.
# Generate a strong random string, e.g. `python -c "import secrets; print(secrets.token_urlsafe(32))"`
APP_TOKEN=

# Paste full contents of ~/.notebooklm/storage_state.json (one line, no surrounding quotes)
# Generate with: notebooklm login  (then `cat ~/.notebooklm/storage_state.json`)
NOTEBOOKLM_AUTH_JSON=

# Optional
NOTEBOOKLM_HOME=/tmp/notebooklm
ARTIFACTS_DIR=/tmp/notebooklm-artifacts
CORS_ORIGINS=*

# Required for /api/admin/refresh-auth endpoint (one-click cookie refresh):
# Render → Account Settings → API Keys → Create API Key
RENDER_API_KEY=
# Render service ID (e.g. srv-xxxxxxx) — found in service URL
RENDER_SERVICE_ID=
